# Web extension build-time environment variables
# Copy to .env.local (or set in CI) before running `pnpm build`.

# Required for protected backend deployments.
VITE_BACKEND_API_KEY=

# Optional: override backend base URL used by extension API calls.
VITE_BACKEND_BASE=https://natfanclub-backend-809989871890.asia-southeast1.run.app

# Optional: override web app base URL used by login/report links.
VITE_FACTGUARD_API_BASE=https://hackomania-three.vercel.app
