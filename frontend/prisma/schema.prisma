generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  displayName  String?  @map("display_name") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  reports      Report[]
  comments     Comment[]
  reportVotes  ReportVote[]
  commentVotes CommentVote[]

  @@map("users")
}

// ─── Posts (canonical content entries, one per unique URL) ────────────────────

model Post {
  id                  String   @id @default(uuid()) @db.Uuid
  sourceUrl           String   @map("source_url") @db.Text
  normalizedUrl       String   @unique @map("normalized_url") @db.VarChar(2048)
  sourceType          String   @map("source_type") @db.VarChar(20)
  headline            String?  @db.VarChar(500)
  thumbnailUrl        String?  @map("thumbnail_url") @db.Text
  scrapedContent      String?  @map("scraped_content") @db.Text
  aiSummary           String?  @map("ai_summary") @db.Text
  aiCredibilityScore  Float?   @map("ai_credibility_score")
  aiTransparencyNotes String?  @map("ai_transparency_notes") @db.Text
  processedStatus      String   @default("pending") @map("processed_status") @db.VarChar(20)
  reportCount         Int      @default(0) @map("report_count")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  reports          Report[]
  comments         Comment[]
  aiPostCategories AiPostCategory[]

  @@index([reportCount(sort: Desc)], map: "idx_posts_report_count")
  @@index([createdAt(sort: Desc)], map: "idx_posts_created_at")
  @@map("posts")
}

// ─── Categories ──────────────────────────────────────────────────────────────

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  aiPostCategories AiPostCategory[]

  @@map("categories")
}

// ─── AiPostCategories (AI-assigned, many-to-many) ───────────────────────────

model AiPostCategory {
  postId     String   @map("post_id") @db.Uuid
  categoryId Int      @map("category_id")
  confidence Float?
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz()

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([categoryId], map: "idx_ai_post_categories_category_id")
  @@map("ai_post_categories")
}

// ─── Reports ─────────────────────────────────────────────────────────────────

model Report {
  id                 String   @id @default(uuid()) @db.Uuid
  postId             String   @map("post_id") @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  headline           String   @db.VarChar(500)
  platform           String   @db.VarChar(50)
  reportDescription  String   @map("report_description") @db.Text
  supportingEvidence String?  @map("supporting_evidence") @db.Text
  status             String   @default("pending") @db.VarChar(20)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  votes ReportVote[]

  @@unique([postId, userId])
  @@index([postId], map: "idx_reports_post_id")
  @@index([userId], map: "idx_reports_user_id")
  @@index([createdAt], map: "idx_reports_created_at")
  @@map("reports")
}

// ─── Comments (post-level, with threading) ───────────────────────────────────

model Comment {
  id              String   @id @default(uuid()) @db.Uuid
  postId          String   @map("post_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  content         String   @db.Text
  parentCommentId String?  @map("parent_comment_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  post          Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  parentComment Comment?   @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       Comment[]  @relation("CommentReplies")

  votes CommentVote[]

  @@index([postId, createdAt], map: "idx_comments_post_created")
  @@map("comments")
}

// ─── Report Votes ────────────────────────────────────────────────────────────

model ReportVote {
  userId    String   @map("user_id") @db.Uuid
  reportId  String   @map("report_id") @db.Uuid
  voteValue Int      @map("vote_value") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@id([userId, reportId])
  @@map("report_votes")
}

// ─── Comment Votes ───────────────────────────────────────────────────────────

model CommentVote {
  userId    String   @map("user_id") @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  voteValue Int      @map("vote_value") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@map("comment_votes")
}
